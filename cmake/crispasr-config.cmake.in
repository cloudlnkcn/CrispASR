set(CRISPASR_VERSION      @CRISPASR_INSTALL_VERSION@)
set(CRISPASR_BUILD_COMMIT @CRISPASR_BUILD_COMMIT@)
set(CRISPASR_BUILD_NUMBER @CRISPASR_BUILD_NUMBER@)
set(CRISPASR_SHARED_LIB   @BUILD_SHARED_LIBS@)

@PACKAGE_INIT@

set_and_check(CRISPASR_INCLUDE_DIR "@PACKAGE_CRISPASR_INCLUDE_INSTALL_DIR@")
set_and_check(CRISPASR_LIB_DIR     "@PACKAGE_CRISPASR_LIB_INSTALL_DIR@")
set_and_check(CRISPASR_BIN_DIR     "@PACKAGE_CRISPASR_BIN_INSTALL_DIR@")

find_package(ggml REQUIRED HINTS ${LLAMA_LIB_DIR}/cmake)

find_library(crispasr_LIBRARY crispasr
    REQUIRED
    HINTS ${CRISPASR_LIB_DIR}
    NO_CMAKE_FIND_ROOT_PATH
)

add_library(crispasr UNKNOWN IMPORTED)
set_target_properties(crispasr
    PROPERTIES
    INTERFACE_INCLUDE_DIRECTORIES "${CRISPASR_INCLUDE_DIR}"
        INTERFACE_LINK_LIBRARIES "ggml::ggml;ggml::ggml-base;"
        IMPORTED_LINK_INTERFACE_LANGUAGES "CXX"
        IMPORTED_LOCATION "${crispasr_LIBRARY}"
        INTERFACE_COMPILE_FEATURES cxx_std_11
        POSITION_INDEPENDENT_CODE ON )

check_required_components(crispasr)
